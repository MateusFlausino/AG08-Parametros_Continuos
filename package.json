{
  "name": "trabalho-8-parametros-continuos",
  "version": "1.0.0",
  "description": "Trabalho 8 - Parametros Continuos",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "desktop": "electron .",
    "dist": "electron-builder --win portable",
    "pack": "electron-builder --dir",
    "start": "node server.js",
    "verify": "node verify.js"
  },
  "keywords": [
    "algoritmo-genetico",
    "tomassini",
    "ga",
    "rastrigin",
    "parametros-continuos"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "pdfjs-dist": "^5.5.207"
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "br.edu.ufu.trabalho8",
    "productName": "Trabalho 8",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "img/**/*",
      "src/**/*",
      "index.html",
      "styles.css",
      "server.js",
      "package.json"
    ],
    "win": {
      "artifactName": "Trabalho-8-portable-${version}.${ext}",
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    }
  }
}
